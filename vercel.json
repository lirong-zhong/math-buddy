{
  "version": 2,
  "outputDirectory": ".",
  "builds": [
    { "src": "api/chat.js", "use": "@vercel/node" },
    { "src": "*", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/chat", "dest": "/api/chat" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
