{
  "version": 2,
  "name": "math-buddy",
  "functions": {
    "api/chat.js": {
      "memory": 256,
      "maxDuration": 30
    }
  },
  "routes": [
    { "src": "/api/chat", "dest": "/api/chat" },
    { "src": "/assets/(.*)", "dest": "/assets/$1" },
    { "src": "/(.*\\.(html|css|js|json|png|ico|svg|txt))", "dest": "/$1" },
    { "src": "/.*", "dest": "/index.html" }
  ]
}
